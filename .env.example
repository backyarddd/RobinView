# ── RobinView configuration ──────────────────────────────────────────────
# Copy to `.env` and edit. Everything has a sensible default.

# Data mode:
#   live  (default) — real live market data; connect Robinhood in-app for your account
#   demo            — deterministic simulator (no network, no auth) for screenshots/CI
ROBINVIEW_MODE=live

# Public origin RobinView is reached at. Used to build the Robinhood OAuth
# redirect URI (`<PUBLIC_URL>/api/robinhood/callback`). Set this if you deploy
# behind a domain; for local use the default is fine.
# ROBINVIEW_PUBLIC_URL=http://localhost:8787

# Robinhood MCP trading server (override only if Robinhood changes the URL).
# ROBINHOOD_MCP_URL=https://agent.robinhood.com/mcp/trading

# Where the Robinhood OAuth session (tokens) is stored. Defaults to ~/.robinview.
# ROBINVIEW_DATA_DIR=~/.robinview

# Ports & live cadence
ROBINVIEW_API_PORT=8787
ROBINVIEW_TICK_MS=1000
