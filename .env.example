# ── RobinView configuration ──────────────────────────────────────────────
# Copy to `.env` and edit. All values are optional; defaults run demo mode.

# Data mode: "demo" (deterministic simulator, no auth) or "live" (Robinhood MCP).
ROBINVIEW_MODE=demo

# Robinhood MCP trading server. Required only when ROBINVIEW_MODE=live.
# The endpoint is OAuth-gated — supply a bearer token from your Robinhood
# agent session. Without a token, RobinView stays in demo mode.
ROBINHOOD_MCP_URL=https://agent.robinhood.com/mcp/trading
# ROBINHOOD_MCP_TOKEN=your-robinhood-agent-token

# Ports
ROBINVIEW_API_PORT=8787

# Live tick cadence in milliseconds (demo simulator + live quote polling).
ROBINVIEW_TICK_MS=1000
